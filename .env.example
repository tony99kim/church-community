# ==============================
# Spring Boot 백엔드 환경변수
# ==============================

# DB (Supabase에서 복사)
DATABASE_URL=jdbc:postgresql://db.xxxx.supabase.co:5432/postgres?user=postgres&password=YOUR_PASSWORD

# Redis (Upstash에서 복사)
REDIS_HOST=your-redis-endpoint.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-upstash-redis-password

# JWT (256비트 이상 랜덤 문자열)
JWT_SECRET=replace-this-with-a-very-long-random-secret-key-at-least-256-bits

# 프론트엔드 URL (Vercel 배포 후 입력)
CORS_ALLOWED_ORIGINS=https://your-user-app.vercel.app,https://your-admin-app.vercel.app

# ==============================
# Next.js 사용자 프론트 환경변수
# ==============================
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com/api/v1

# ==============================
# React 관리자 프론트 환경변수
# ==============================
VITE_API_URL=https://your-backend.onrender.com/api/v1
